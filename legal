            color: #2d3748;
            font-size: 1.4rem;
            margin-bottom: 1rem;
        }

        .contact-card h6 {
            color: #4a5568;
            font-size: 0.9rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 1.5rem 0 0.5rem 0;
