        .row {
            display: flex;
            flex-wrap: wrap;
            margin: 0 -15px;
        }

        .col-12 { width: 100%; padding: 0 15px; }
        .col-md { width: 100%; }
        .col-md-4 { width: 33.333%; }
        .col-md-8 { width: 66.666%; }

        @media (min-width: 768px) {
            .col-md { width: 50%; }
        }

